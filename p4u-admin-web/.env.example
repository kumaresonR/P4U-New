# Copy to .env.production on the server before `npm run build`.
# Required in production — without this, login POSTs hit the static nginx host (405).

VITE_API_GATEWAY_URL=https://api.planext4u.com

# Local dev only — Vite proxies /api to the gateway (see vite.config.js)
# VITE_DEV_PROXY_TARGET=http://localhost:8080
# VITE_ADMIN_SERVICE_URL=http://localhost:8082
