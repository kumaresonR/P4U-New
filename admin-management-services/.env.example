SERVER_PORT=8082
NODE_ENV=development
SERVICE_HOST=localhost

# MySQL (dedicated DB recommended for admin tables)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root@123
DB_NAME=p4u_admin_db
#
# vendor_plans: created automatically on admin service startup if missing (see schemaRepair).
# Optional manual run: npm run migrate:vendor-plans (creates DB if needed, then the table).

# Same Keycloak realm as auth-management-services
KEYCLOAK_SERVER_URL=http://localhost:8180
KEYCLOAK_REALM=p4u-realm
# JWT_ISSUER_URI=http://localhost:8180/realms/p4u-realm

DISCOVERY_SERVICE_URL=http://localhost:8761

# Media Library — Browse B2 / migrate (optional; S3-compatible B2 endpoint)
# B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_S3_REGION=us-west-004
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=
# Public URL prefix for migrated or public files (e.g. https://f003.backblazeb2.com/file/your-bucket)
# B2_PUBLIC_FILE_BASE=https://f003.backblazeb2.com/file/your-bucket
#
# admin_bulk_upload_jobs: created on startup if missing (File Uploads CSV history).
