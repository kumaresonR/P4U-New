{
  "info": {
    "name": "P4U Tech",
    "description": "Aligned with PROJECT-STATUS.md (repo root). All routes hit p4u-api-gateway-services by default (same as NEXT_PUBLIC_API_GATEWAY_URL / VITE_API_GATEWAY_URL). Path prefixes: /health, /api/auth/*, /api/admin/*, /uploads/*, /api/v1/catalog|content|profile|commerce|payments|notifications|vendor|social/*. Override collection variable gateway_url only if your gateway binds elsewhere; for direct-to-service debugging use each service port from its .env.example.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway_url", "value": "http://localhost:8080" },
    { "key": "access_token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "API Gateway",
      "item": [
        { "name": "Gateway Health", "request": { "method": "GET", "url": "{{gateway_url}}/health" } },
        { "name": "Gateway Root (endpoint index)", "request": { "method": "GET", "url": "{{gateway_url}}/" } }
      ]
    },
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{gateway_url}}/api/auth/public/health" }
        },
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/auth/public/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"userType\": \"CUSTOMER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/auth/public/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/auth/public/refresh?refreshToken=YOUR_REFRESH_TOKEN"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"YOUR_REFRESH_TOKEN\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/auth/public/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/auth/change-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\"\n}" }
          }
        },
        {
          "name": "Introspect Token",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/auth/introspect",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Introspect-Secret", "value": "your-introspect-secret" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{access_token}}\"\n}" }
          }
        },
        {
          "name": "Customer Info",
          "request": { "method": "GET", "url": "{{gateway_url}}/api/auth/customer/info" }
        },
        {
          "name": "Vendor Info",
          "request": { "method": "GET", "url": "{{gateway_url}}/api/auth/vendor/info" }
        },
        {
          "name": "Admin Info",
          "request": { "method": "GET", "url": "{{gateway_url}}/api/auth/admin/info" }
        }
      ]
    },
    {
      "name": "Catalog Service",
      "item": [
        { "name": "Health", "request": { "method": "GET", "url": "{{gateway_url}}/api/v1/catalog/public/health" } },
        { "name": "List Categories", "request": { "method": "GET", "url": "{{gateway_url}}/api/v1/catalog/categories?limit=20&offset=0" } },
