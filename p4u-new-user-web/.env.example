# Copy this to .env.local and update values as needed

# API Gateway — one URL for auth, catalog, profile, commerce, etc. (default :8080).
# For local auth only without gateway, use http://localhost:8081 instead.
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080

# Razorpay public key (RAZORPAY_KEY_ID). Used by checkout.js to open the
# payment modal. The matching RAZORPAY_KEY_SECRET must be set in
# payment-management-services (never exposed to the client).
NEXT_PUBLIC_RAZORPAY_KEY_ID=
