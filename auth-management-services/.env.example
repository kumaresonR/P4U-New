# Server
SERVER_PORT=8081
NODE_ENV=development
SERVICE_HOST=localhost

# Database (TypeORM / MySQL) — same default DB as catalog, commerce, admin, etc.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root@123
DB_NAME=p4u_admin_db

# Keycloak
KEYCLOAK_SERVER_URL=http://localhost:8180
KEYCLOAK_REALM=p4u-realm
KEYCLOAK_CLIENT_ID=auth-management-client
# Must match Keycloak client "Credentials" tab. Client must allow **Direct access grants**
# (Settings) — phone signup uses password grant on this confidential client after OTP.
KEYCLOAK_CLIENT_SECRET=

# Optional: override JWT issuer for middleware (defaults from KEYCLOAK_SERVER_URL + realm)
# JWT_ISSUER_URI=http://localhost:8180/realms/p4u-realm

# Service-to-service only: required for POST /api/auth/introspect (header X-Introspect-Secret)
# Do not ship this to mobile apps. Min 8 characters; use a long random value in production.
INTROSPECT_API_KEY=change-me-to-a-long-random-secret

# After phone OTP, customer has this many seconds to POST /public/customer/register-by-phone (60–86400). Default 3600.
# PHONE_REG_TOKEN_TTL_SECONDS=3600

# Discovery (optional)
# DISCOVERY_SERVICE_URL=http://localhost:8761
