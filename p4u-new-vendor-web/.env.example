# Copy to .env.local

# Optional. Leave unset to call same-origin /api/* (Next.js rewrites to the gateway — avoids CORS).
# Set to your gateway URL if you prefer the browser to talk to it directly (gateway must allow CORS).
# NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080

# Override rewrite target (defaults to NEXT_PUBLIC_API_GATEWAY_URL or http://localhost:8080)
# API_GATEWAY_PROXY_TARGET=http://localhost:8080
