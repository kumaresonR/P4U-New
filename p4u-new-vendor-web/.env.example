# Copy to .env.local or .env.production on the server

# Production (vendor.planext4u.com):
# NEXT_PUBLIC_API_GATEWAY_URL=https://api.planext4u.com
# API_GATEWAY_PROXY_TARGET=http://127.0.0.1:8080

# Optional. Leave unset locally to call same-origin /api/* (Next.js rewrites to the gateway — avoids CORS).
# NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080

# Override rewrite target (defaults to NEXT_PUBLIC_API_GATEWAY_URL or http://localhost:8080)
# API_GATEWAY_PROXY_TARGET=http://localhost:8080

# Firebase Phone Auth (required for vendor OTP login)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Google Maps (optional)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
